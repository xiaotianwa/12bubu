{
  "name": "yier-bubu-desktop-pet",
  "version": "0.1.0",
  "description": "一二布布多功能 Windows 桌宠 MVP",
  "author": "Yier Bubu",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && electron .",
    "assets:optimize": "python scripts/optimize-frames.py",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder --win nsis portable",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.yierbubu.desktoppet",
    "productName": "一二布布桌宠",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/pet/frames/**/*.png",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icons",
        "to": "assets/icons"
      }
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "一二布布桌宠-${version}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "一二布布桌宠-${version}-portable.${ext}"
    }
  }
}
